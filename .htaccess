DirectoryIndex index.html index.php

# PHP — langere timeout voor grote database-load (voorkomt 504)
<IfModule mod_fcgid.c>
  FcgidIOTimeout 300
  FcgidConnectTimeout 60
</IfModule>

# Gevoelige bestanden — niet publiek downloadbaar
<FilesMatch "\.(csv|json)$">
  Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^api/config\.php$ - [F,L]
</IfModule>

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
</IfModule>

# Grote seed — gzip indien beschikbaar
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE application/json text/javascript text/css text/html
</IfModule>
